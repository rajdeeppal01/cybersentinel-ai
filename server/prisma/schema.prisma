// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(ANALYST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ANALYST
  ADMIN
}

model RiskRegister {
  id               String   @id @default(uuid())
  framework        String
  overallScore     Float
  status           String
  summary          String
  gaps             Json
  createdAt        DateTime @default(now())
}

model ThreatLog {
  id               String   @id @default(uuid())
  sourceIp         String
  destIp           String
  severity         String
  detectedThreat   String
  confidence       Float
  mitreCode        String
  mitreName        String
  analysisSummary  String
  createdAt        DateTime @default(now())
}
